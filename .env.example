# ==========================================
# BASE DE DATOS CENTRAL (destino)
# ==========================================
CENTRAL_DB_HOST=postgres-central
CENTRAL_DB_PORT=5432
CENTRAL_DB_NAME=central_warehouse
CENTRAL_DB_USER=etl_writer
CENTRAL_DB_PASSWORD=changeme_central

# ==========================================
# BASES DE DATOS ORIGEN
# Formato: SOURCE_<ALIAS>_<CAMPO>
# El ALIAS se usa como prefijo de las tablas destino
# ==========================================

# --- Fuente 1: db1 ---
SOURCE_DB1_HOST=source-db1
SOURCE_DB1_PORT=5432
SOURCE_DB1_DBNAME=db1
SOURCE_DB1_USER=readonly_user
SOURCE_DB1_PASSWORD=changeme_db1
SOURCE_DB1_SCHEMAS=esquema1,esquema2,esquema3

# --- Fuente 2: db2 ---
SOURCE_DB2_HOST=source-db2
SOURCE_DB2_PORT=5432
SOURCE_DB2_DBNAME=db2
SOURCE_DB2_USER=readonly_user
SOURCE_DB2_PASSWORD=changeme_db2
SOURCE_DB2_SCHEMAS=public,ventas

# Lista de alias activos (separados por coma)
ACTIVE_SOURCES=DB1,DB2

# ==========================================
# CONFIGURACIÓN SPARK
# ==========================================
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g
SPARK_JDBC_FETCHSIZE=2000
SPARK_JDBC_BATCHSIZE=1000
SPARK_JDBC_NUM_PARTITIONS=8

# ==========================================
# AIRFLOW
# ==========================================
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=changeme_airflow_secret
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme_admin

# ==========================================
# COMPORTAMIENTO ETL
# ==========================================
# Columnas candidatas para detección incremental (en orden de preferencia)
INCREMENTAL_COLUMNS=updated_at,modified_at,fecha_modificacion,created_at,id
# Si no hay columna incremental, hacer full refresh
FALLBACK_TO_FULL_REFRESH=true
# Tablas a excluir (formato: schema.tabla, separadas por coma). Opcional.
EXCLUDED_TABLES=
